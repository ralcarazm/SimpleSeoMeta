msgstr ""

msgid "Enable Open Graph"
msgstr ""

msgid "Default og:type"
msgstr ""

msgid "Usually website. You may also use article or another Open Graph type."
msgstr ""

msgid "og:locale"
msgstr ""

msgid "Optional. Example: es_ES, ca_ES, en_GB."
msgstr ""

msgid "Default image URL"
msgstr ""

msgid "Absolute or root-relative URL. For item pages, the plugin tries to use the first image file before this fallback."
